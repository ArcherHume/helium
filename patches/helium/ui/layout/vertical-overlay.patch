+void BrowserView::UpdateVerticalOverlayMode() {
+  if (!vertical_tab_strip_region_view_) {
+    return;
+  }
+  auto* controller = tabs::VerticalTabStripStateController::From(browser_);
+  const bool overlay_mode =
+      controller && controller->ShouldDisplayVerticalTabs() &&
+      controller->IsOverlayMode();
+
+  vertical_tab_strip_region_view_->SetOverlayMode(overlay_mode);
+
+  if (vertical_overlay_hover_zone_) {
+    vertical_overlay_hover_zone_->SetVisible(overlay_mode);
+  }
+
+  if (overlay_mode) {
+    // Reorder the vertical tab strip to the top of the Z-order so it paints
+    // above the web contents, top container, etc.
+    ReorderChildView(vertical_tab_strip_region_view_, children().size());
+    if (vertical_overlay_hover_zone_) {
+      // The hover zone should receive pointer input but paint below the
+      // overlay; keep it just below the strip.
+      ReorderChildView(vertical_overlay_hover_zone_, children().size() - 1);
+
+      // Forward pointer enter/exit on the strip itself to the hover zone so
+      // that moving the mouse into the overlay card doesn't dismiss it. The
+      // hover zone and the strip are both owned by this BrowserView, so the
+      // raw pointer is safe for the lifetime of this callback (which is
+      // cleared when overlay mode is turned off or either view is destroyed).
+      vertical_tab_strip_region_view_->SetOverlayPointerCallback(
+          base::BindRepeating(
+              [](VerticalOverlayHoverZone* hz, bool entered) {
+                if (entered) {
+                  hz->OnOverlayPointerEntered();
+                } else {
+                  hz->OnOverlayPointerExited();
+                }
+              },
+              base::Unretained(vertical_overlay_hover_zone_.get())));
+    }
+  } else if (vertical_tab_strip_region_view_) {
+    vertical_tab_strip_region_view_->SetOverlayPointerCallback({});
+  }
+}
+
+void BrowserView::OnVerticalOverlayHoverVisibilityChanged(bool visible) {
+  if (vertical_tab_strip_region_view_) {
+    vertical_tab_strip_region_view_->SetOverlayVisible(visible);
