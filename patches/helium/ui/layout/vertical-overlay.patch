+void VerticalTabStripRegionView::SetOverlayMode(bool overlay_mode) {
+  if (overlay_mode_ == overlay_mode) {
+    return;
+  }
+  overlay_mode_ = overlay_mode;
+
+  if (overlay_mode_) {
+    // Paint the overlay into its own layer so we can slide + drop-shadow it.
+    SetPaintToLayer();
+    layer()->SetFillsBoundsOpaquely(false);
+    overlay_slide_animation_.SetSlideDuration(base::Milliseconds(180));
+    overlay_slide_animation_.SetTweenType(gfx::Tween::Type::EASE_OUT);
+    // Force uncollapsed form: the floating overlay card is always rendered
+    // in its uncollapsed form. We update the controller so child views that
+    // read IsCollapsed() render correctly; the previous collapsed choice is
+    // naturally restored when the user switches back to docked Vertical mode
+    // because that pref write only happens during resize interactions.
+    if (state_controller_ && state_controller_->IsCollapsed()) {
+      state_controller_->SetCollapsed(false);
+    }
+    // Start hidden (off-screen) but keep the view itself visible so that
+    // the layout engine still sizes it.
+    overlay_visible_ = false;
+    overlay_slide_animation_.Reset(0.0);
+    AnimationProgressed(&overlay_slide_animation_);
+  } else {
+    DestroyLayer();
+    overlay_visible_ = true;
+  }
+  UpdateInteriorMargin();
+  InvalidateLayout();
+  SchedulePaint();
+}
+
+void VerticalTabStripRegionView::OnMouseEntered(const ui::MouseEvent& /*event*/) {
+  if (overlay_mode_ && overlay_pointer_callback_) {
+    overlay_pointer_callback_.Run(true);
+  }
+}
+
+void VerticalTabStripRegionView::OnMouseExited(const ui::MouseEvent& /*event*/) {
+  if (overlay_mode_ && overlay_pointer_callback_) {
+    overlay_pointer_callback_.Run(false);
+  }
+}
+
+void VerticalTabStripRegionView::SetOverlayPointerCallback(
+    OverlayPointerCallback callback) {
+  overlay_pointer_callback_ = std::move(callback);
+}
+
+void VerticalTabStripRegionView::SetOverlayVisible(bool visible) {
+  if (!overlay_mode_) {
+    return;
+  }
+  if (overlay_visible_ == visible) {
+    return;
+  }
+  overlay_visible_ = visible;
+  if (visible) {
+    overlay_slide_animation_.Show();
+  } else {
+    overlay_slide_animation_.Hide();
+  }
+}
