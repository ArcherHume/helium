+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_VERTICAL_OVERLAY_HOVER_ZONE_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_VERTICAL_OVERLAY_HOVER_ZONE_H_
+
+#include "base/functional/callback.h"
+#include "base/timer/timer.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+#include "ui/views/view.h"
+
+// A thin, transparent hot-zone view placed along the leading (or trailing)
+// edge of the browser when the Vertical Overlay layout is active. Hovering
+// this zone reveals the floating vertical tab strip overlay; moving the
+// pointer away (with a short grace window) hides it again.
+class VerticalOverlayHoverZone : public views::View {
+  METADATA_HEADER(VerticalOverlayHoverZone, views::View)
+
+ public:
+  using VisibilityChangedCallback = base::RepeatingCallback<void(bool visible)>;
+
+  explicit VerticalOverlayHoverZone(VisibilityChangedCallback callback);
+  VerticalOverlayHoverZone(const VerticalOverlayHoverZone&) = delete;
+  VerticalOverlayHoverZone& operator=(const VerticalOverlayHoverZone&) = delete;
+  ~VerticalOverlayHoverZone() override;
+
+  // Used by the overlay strip itself: when the pointer enters/exits the
+  // overlay card, we keep it visible/schedule a dismiss the same way as the
+  // hover zone does.
+  void OnOverlayPointerEntered();
+  void OnOverlayPointerExited();
+
+  // views::View:
+  void OnMouseEntered(const ui::MouseEvent& event) override;
+  void OnMouseExited(const ui::MouseEvent& event) override;
+
+ private:
+  void Show();
+  void ScheduleHide();
+
+  VisibilityChangedCallback callback_;
+  bool visible_ = false;
+  base::OneShotTimer hide_timer_;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_VERTICAL_OVERLAY_HOVER_ZONE_H_
--- /dev/null
+++ b/chrome/browser/ui/views/frame/vertical_overlay_hover_zone.cc
@@ -0,0 +1,72 @@
+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/views/frame/vertical_overlay_hover_zone.h"
+
+#include <utility>
+
+#include "base/time/time.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+
+namespace {
+// Grace period before dismissing the overlay after the pointer leaves both
+// the hover zone and the overlay strip. Arc uses a similar delay to avoid
+// accidental dismissals when the user briefly overshoots.
+constexpr base::TimeDelta kHideDelay = base::Milliseconds(250);
+}  // namespace
+
+VerticalOverlayHoverZone::VerticalOverlayHoverZone(
+    VisibilityChangedCallback callback)
+    : callback_(std::move(callback)) {
+  // The hover zone is transparent and doesn't intercept clicks; it only
+  // reports mouse-enter/exit events.
+  SetCanProcessEventsWithinSubtree(true);
+  SetNotifyEnterExitOnChild(true);
+}
+
+VerticalOverlayHoverZone::~VerticalOverlayHoverZone() = default;
+
+void VerticalOverlayHoverZone::OnMouseEntered(const ui::MouseEvent& /*event*/) {
+  Show();
+}
+
+void VerticalOverlayHoverZone::OnMouseExited(const ui::MouseEvent& /*event*/) {
+  ScheduleHide();
+}
+
+void VerticalOverlayHoverZone::OnOverlayPointerEntered() {
+  Show();
+}
+
+void VerticalOverlayHoverZone::OnOverlayPointerExited() {
+  ScheduleHide();
+}
+
+void VerticalOverlayHoverZone::Show() {
+  hide_timer_.Stop();
+  if (visible_) {
+    return;
+  }
+  visible_ = true;
+  if (callback_) {
+    callback_.Run(true);
+  }
+}
+
+void VerticalOverlayHoverZone::ScheduleHide() {
+  hide_timer_.Start(FROM_HERE, kHideDelay, base::BindOnce(
+                                                [](VerticalOverlayHoverZone* self) {
+                                                  if (!self->visible_) {
+                                                    return;
+                                                  }
+                                                  self->visible_ = false;
+                                                  if (self->callback_) {
+                                                    self->callback_.Run(false);
+                                                  }
+                                                },
+                                                base::Unretained(this)));
+}
+
+BEGIN_METADATA(VerticalOverlayHoverZone)
+END_METADATA
